<UserControl
    x:Class="Portal.Views.Pages.InstancePages.WorldSaveGameRules"
    x:DataType="local:WorldSaveDetailsViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:local="clr-namespace:Portal.Views.Pages.InstancePages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Spacing="8">
            <TextBlock
                FontSize="22"
                FontWeight="SemiBold"
                Text="游戏规则" />
            <TextBlock
                Foreground="{DynamicResource InnerForegroundColor}"
                Text="显示 game_rules.dat 中全部可编辑的布尔和整数规则。"
                TextWrapping="Wrap" />
        </StackPanel>
        <controls:ScrollView Grid.Row="1" Margin="0,14,0,0">
            <StackPanel Margin="0,7,0,0" Spacing="8">
                <TextBlock IsVisible="{Binding IsLoading}" Text="正在读取设置..." />
                <TextBlock IsVisible="{Binding !HasGameRules}" Text="此世界未找到可编辑的游戏规则文件。" />
                <ItemsRepeater ItemsSource="{Binding BooleanRules}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:WorldBooleanSetting">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                <ToggleSwitch
                                    Grid.Column="1"
                                    IsChecked="{Binding Value}"
                                    OffContent="false"
                                    OnContent="true" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <ItemsRepeater ItemsSource="{Binding IntegerRules}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:WorldNumberSetting">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                <TextBox
                                    Grid.Column="1"
                                    PlaceholderText="非负整数"
                                    Text="{Binding Value}"
                                    Width="130" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </controls:ScrollView>
        <Button
            Command="{Binding SaveGameRulesCommand}"
            Content="保存"
            Grid.Row="2"
            HorizontalAlignment="Right"
            IsEnabled="{Binding HasGameRules}"
            IsVisible="{Binding !IsLocked}"
            Margin="0,12,0,0" />
    </Grid>
</UserControl>