<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.Pages.SettingPages.Storage"
    x:DataType="settingPages:StorageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingPages="clr-namespace:Portal.Views.Pages.SettingPages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <DockPanel Margin="10">
            <StackPanel DockPanel.Dock="Left" HorizontalAlignment="Left">
                <Border
                    CornerRadius="10"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,2"
                    Padding="5,3,5,1">
                    <Border.Background>
                        <SolidColorBrush Color="#1890ff" Opacity="0.2" />
                    </Border.Background>
                    <TextBlock
                        FontSize="11"
                        Foreground="#1890ff"
                        Text="总计" />
                </Border>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="42" Text="{Binding TotalSizeString}" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                DockPanel.Dock="Right"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="15">
                <StackPanel>
                    <Border
                        CornerRadius="10"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,2"
                        Padding="5,3,5,1">
                        <Border.Background>
                            <SolidColorBrush Color="#cc4e00" Opacity="0.2" />
                        </Border.Background>
                        <TextBlock
                            FontSize="11"
                            Foreground="#cc4e00"
                            Text="Portal" />
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="42" Text="{Binding PortalSizeString}" />
                    </StackPanel>
                </StackPanel>
                <Rectangle
                    Fill="{DynamicResource LineColor}"
                    Margin="0,4,0,10"
                    VerticalAlignment="Stretch"
                    Width="1" />
                <StackPanel>
                    <Border
                        CornerRadius="10"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,2"
                        Padding="5,3,5,1">
                        <Border.Background>
                            <SolidColorBrush Color="#953ea3" Opacity="0.2" />
                        </Border.Background>
                        <TextBlock
                            FontSize="11"
                            Foreground="#953ea3"
                            Text="游戏" />
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="42" Text="{Binding GameSizeString}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <Separator Background="{DynamicResource LineColor}" Margin="0,5,0,15" />

        <StackPanel>
            <Border
                Background="{DynamicResource PopupBackgroundColor}"
                BorderBrush="{DynamicResource PopupBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
                <StackPanel>
                    <DockPanel>
                        <TextBlock
                            HorizontalAlignment="Left"
                            Margin="5,0,0,0"
                            Text="Portal 数据文件夹" />
                        <TextBlock
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding IsWindowsPlatform}"
                            Margin="0,0,5,0">
                            <Run Text="{Binding PortalSizeString, Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding SystemDriveSizeString, Mode=OneWay}" />
                            <Run Text=" &gt; " />
                            <Run Text="{Binding PortalPercentage, StringFormat=\{0:F0\}%, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding !IsWindowsPlatform}"
                            Margin="0,0,5,0">
                            <Run Text="{Binding PortalSizeString, Mode=OneWay}" />
                        </TextBlock>
                    </DockPanel>

                    <ProgressBar
                        IsVisible="{Binding IsWindowsPlatform}"
                        Margin="3,6,3,0"
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding PortalPercentage}" />

                    <DockPanel Margin="0,6,0,0">
                        <Label
                            Content="Portal 用户数据，删除将丢失所有账户信息、游戏设置等"
                            FontSize="13"
                            Foreground="{DynamicResource InnerForegroundColor}"
                            Margin="5,0,0,0" />
                        <HyperlinkButton
                            Click="OpenFolder_Click"
                            Content="打开文件夹"
                            FontSize="12"
                            HorizontalAlignment="Right"
                            Margin="0,0,5,0"
                            Theme="{StaticResource TransparentHyperlinkButton}" />
                    </DockPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>