<tio:TioWindow
    ExtendClientAreaToDecorationsHint="{OnPlatform Default=True,
                                                   macOS=False}"
    Icon="/Assets/avalonia-logo.ico"
    IsCloseBtnShow="{OnPlatform Default=True,
                                macOS=False}"
    IsMaxBtnShow="{OnPlatform Default=True,
                              macOS=False}"
    IsMinBtnShow="{OnPlatform Default=True,
                              macOS=False}"
    Title="Portal"
    TitleBarControlBtnMargin="0,0,4,0"
    TitleBarHeight="44"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Portal.Views.MainWindow"
    x:DataType="views:MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:common="clr-namespace:Tio.Avalonia.Standard.Tab.Common;assembly=Tio.Avalonia.Standard.Tab"
    xmlns:converter="clr-namespace:Portal.Module.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entries="clr-namespace:Tio.Avalonia.Standard.Tab.Entries;assembly=Tio.Avalonia.Standard.Tab"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:views="clr-namespace:Portal.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:TioWindow.Resources>
        <SolidColorBrush Color="Transparent" x:Key="TitleBarBackgroundColor" />
        <common:NavScrollOpacityMaskConverter x:Key="NavScrollOpacityMaskConverter" />
        <converter:IntCompareConverter x:Key="IntCompareConverter" />
    </tio:TioWindow.Resources>
    <tio:TioWindow.TitleBarLeftContent>
        <StackPanel
            Margin="{OnPlatform Default=8 0 0 0,
                                macOS=99 0 0 0}"
            Orientation="Horizontal"
            VerticalAlignment="Center">
            <Rectangle
                Fill="Red"
                Height="22"
                IsVisible="False"
                Width="22" />
            <TextBlock
                FontSize="16"
                Margin="12,2,0,0"
                Text="Portal"
                VerticalAlignment="Center" />
        </StackPanel>
    </tio:TioWindow.TitleBarLeftContent>
    <Grid>
        <ScrollViewer
            Background="Transparent"
            Classes="Flat"
            Height="44"
            HorizontalAlignment="Left"
            HorizontalScrollBarVisibility="Auto"
            Margin="85,-44,85,0"
            Name="NavScrollViewer"
            OpacityMask="{Binding IsTabMaskVisible, Converter={StaticResource NavScrollOpacityMaskConverter}}"
            PointerWheelChanged="InputElement_OnPointerWheelChanged"
            VerticalAlignment="Top"
            VerticalScrollBarVisibility="Disabled">
            <DockPanel>
                <tio:SelectionList
                    Indicator="{x:Null}"
                    ItemsSource="{Binding Tabs}"
                    Name="TabSelectionList"
                    SelectedItem="{Binding SelectedTab}">
                    <tio:SelectionList.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </tio:SelectionList.ItemsPanel>
                    <tio:SelectionList.ItemTemplate>
                        <DataTemplate DataType="entries:TabEntry">
                            <Border
                                Classes="tab-root"
                                CornerRadius="10"
                                Height="30"
                                Margin="3,1,3,0"
                                MinWidth="{Binding MinWidth}"
                                Name="ItemRoot"
                                PointerPressed="OnPointerPressed"
                                Tag="{Binding}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem
                                            Command="{Binding Close}"
                                            Header="关闭标签页"
                                            InputGesture="ctrl+w"
                                            IsVisible="{Binding IsCloseable}">
                                            <MenuItem.Icon>
                                                <PathIcon
                                                    Data="M13.41 12l4.3-4.29a1 1 0 1 0-1.42-1.42L12 10.59l-4.29-4.3a1 1 0 0 0-1.42 1.42l4.3 4.29-4.3 4.29a1 1 0 0 0 0 1.42 1 1 0 0 0 1.42 0l4.29-4.3 4.29 4.3a1 1 0 0 0 1.42 0 1 1 0 0 0 0-1.42z"
                                                    Height="12"
                                                    Margin="2,-2.5,0,0"
                                                    VerticalAlignment="Center"
                                                    Width="12" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem
                                            Command="{Binding CloseOther}"
                                            Header="关闭其他标签页"
                                            IsVisible="{Binding Window.Tabs.Count, Converter={StaticResource IntCompareConverter}, ConverterParameter='&gt; 1'}" />
                                        <!-- <MenuItem Command="{Binding MoveTabToNewWindow}" Header="在新窗口打开" /> -->
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <DockPanel Margin="8,0,10,0" VerticalAlignment="Center">
                                    <PathIcon
                                        Data="{Binding Icon}"
                                        Height="20"
                                        IsVisible="{Binding IsIconVisible}"
                                        Margin="0,0,4,0"
                                        Width="20" />
                                    <Grid>
                                        <ContentControl
                                            Content="{Binding Header}"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid
                                        HorizontalAlignment="Right"
                                        IsVisible="{Binding IsCloseable}"
                                        Margin="0,0,-4,0">
                                        <Button
                                            Command="{Binding Close}"
                                            HorizontalAlignment="Right"
                                            Margin="20,0,4,0"
                                            MaxHeight="14"
                                            MaxWidth="16"
                                            MinHeight="14"
                                            Name="CloseButton"
                                            Theme="{StaticResource TransparentButton}"
                                            VerticalAlignment="Center">
                                            <Button.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Duration="0:0:0.07" Property="Opacity" />
                                                </Transitions>
                                            </Button.Transitions>
                                            <PathIcon
                                                Data="M13.41 12l4.3-4.29a1 1 0 1 0-1.42-1.42L12 10.59l-4.29-4.3a1 1 0 0 0-1.42 1.42l4.3 4.29-4.3 4.29a1 1 0 0 0 0 1.42 1 1 0 0 0 1.42 0l4.29-4.3 4.29 4.3a1 1 0 0 0 1.42 0 1 1 0 0 0 0-1.42z"
                                                Height="10"
                                                Width="10" />
                                        </Button>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </tio:SelectionList.ItemTemplate>
                </tio:SelectionList>
                <Button
                    Classes="tab-add-btn"
                    Click="Button_OnClick"
                    CornerRadius="10"
                    DockPanel.Dock="Right"
                    Height="30"
                    Margin="3,0,25,0"
                    Theme="{StaticResource TransparentButton}"
                    Width="30">
                    <PathIcon
                        Data="F1 M1024,1024z M0,0z M512,832A32,32,0,0,0,544,800L544,544 800,544A32,32,0,0,0,800,480L544,480 544,224A32,32,0,0,0,480,224L480,480 224,480A32,32,0,0,0,224,544L480,544 480,800A32,32,0,0,0,512,832"
                        Height="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="22" />
                </Button>
            </DockPanel>
        </ScrollViewer>
        <ContentControl Content="{Binding SelectedTab.Content}" />
    </Grid>
</tio:TioWindow>
